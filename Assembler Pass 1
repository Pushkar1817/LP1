class Mnemonics {
private:
    map<string, pair<string, int>> IS = {
        {"STOP", {"IS", 0}},
        {"ADD", {"IS", 1}},
        {"SUB", {"IS", 2}},
        {"MUL", {"IS", 3}},
        {"MOVER", {"IS", 4}},
        {"MOVEM", {"IS", 5}},
        {"COMP", {"IS", 6}},
        {"BC", {"IS", 7}},
        {"DIV", {"IS", 8}},
        {"READ", {"IS", 9}},
        {"PRINT", {"IS", 10}},
    };

    map<string, pair<string, int>> AD = {
        {"START", {"AD", 0}},
        {"END", {"AD", 1}},
        {"ORIGIN", {"AD", 2}},
        {"EQU", {"AD", 3}},
        {"LTORG", {"AD", 4}}
    };

    map<string, pair<string, int>> DL = {
        {"DC", {"DL", 0}},
        {"DS", {"DL", 1}}
    };

    map<string, int> REG = {
        {"AREG", 1},
        {"BREG", 2},
        {"CREG", 3},
        {"DREG", 4}
    };

    map<string, int> COND = {
        {"LT", 1},
        {"LE", 2},
        {"EQ", 3},
        {"GT", 4},
        {"GE", 5},
        {"ANY", 6}
    };

public:
    friend class asmPass1;
};

class asmPass1 {
private:
    vector<vector<string>> inputCode;
    vector<string> interCode;
    vector<string> lbl;
    map<string, int> symTab;
    vector<pair<string, int>> litTab;
    vector<int> poolTab;
    int poolInd = 0;
    int loc_counter = 0;

public:
    Mnemonics m;

    asmPass1(vector<vector<string>>& inputCode) {
        this->inputCode = inputCode;
        poolTab.push_back(0); 
    }

    string getOpcode(string op) {
        if (op == "-")
            return "";
        if (m.REG.find(op) != m.REG.end())
            return "(R," + to_string(m.REG[op]) + ")";
        if (m.COND.find(op) != m.COND.end())
            return "(C," + to_string(m.COND[op]) + ")";
        if (op[0] == '=') {
            litTab.push_back({op, -1});
            return "(L," + to_string(litTab.size() - 1) + ")";
        } 
        if(isdigit(op[0])){
            return"(C,"+op+")";
        }
        else {
            if (find(lbl.begin(), lbl.end(), op) == lbl.end()) {
                symTab[op] = 0;
                lbl.push_back(op);
            }
            int index = distance(lbl.begin(), find(lbl.begin(), lbl.end(), op));
            return "(S," + to_string(index) + ")";
        }
    }

    void processLiterals(int loc_counter) {
        for (int i = 0; i < litTab.size(); i++) {
            if (litTab[i].second == -1) {
                litTab[i].second = loc_counter;
                loc_counter++;
            }
        }
        poolInd++; 
        poolTab.push_back(poolInd);
    }

    int evalExpress(string op) {
        if (isdigit(op[0]))
            return stoi(op);
        if (symTab.find(op) != symTab.end())
            return symTab[op];
        return 0;
    }

    void pass1() {
        for (auto& line : inputCode) {
            // string label = line[0];
            // string instrc = line[1];
            // string op1 = line[2];
            // string op2 = line[3];
            string label="-" ;
            string instrc ="-";
            string op1 ="-";
            string op2 ="-";

            for(int i =0 ;i< line.size();i++){
                if(i == 0 && m.IS.find(line[i]) == m.IS.end() && m.AD.find(line[i]) == m.AD.end() && m.DL.find(line[i]) == m.DL.end())
                    label = line[i];
                else if(m.IS.find(line[i]) != m.IS.end() || m.AD.find(line[i]) != m.AD.end() || m.DL.find(line[i]) != m.DL.end())
                    instrc = line[i];
                else{
                    if(op1 == "-")
                        op1 = line[i];
                    else 
                        op2 = line[i];
                }
            }

            string interLine = "";

            if (label != "-" && label != " ") {
                symTab[label] = loc_counter;
                lbl.push_back(label);
            }

            if (m.IS.find(instrc) != m.IS.end()) {
                interLine += "(" + m.IS[instrc].first + "," + to_string(m.IS[instrc].second) + ")";
                interLine += getOpcode(op1) + getOpcode(op2);
                loc_counter++;
            } 
            else if (m.AD.find(instrc) != m.AD.end()) {
                interLine += "(" + m.AD[instrc].first + "," + to_string(m.AD[instrc].second) + ")";
                interLine += getOpcode(op1);

                if (instrc == "LTORG" || instrc == "END") {
                    processLiterals(loc_counter);
                } else if (instrc == "START") {
                    loc_counter = stoi(op1) - 1;
                } else if (instrc == "EQU") {
                    symTab[label] = evalExpress(op1);
                } else {
                    loc_counter = evalExpress(op1) - 1;
                }
                loc_counter++;
            } 
            else if (m.DL.find(instrc) != m.DL.end()) {
                interLine += "(" + m.DL[instrc].first + "," + to_string(m.DL[instrc].second) + ")";
                interLine+=getOpcode(op1);
                if (instrc == "DS") {
                    loc_counter += stoi(op1);
                } else {
                    loc_counter++;
                }
            }

            interCode.push_back(interLine);
        }
    }

    void showTables() {
        cout << "\nINTERMEDIATE CODE\n";
        ofstream inc("intermidiate_code.txt");
        for (auto& i : interCode) {
            cout << i << endl;
            inc<<i<<endl;
        }
        inc.close();

        cout << "\nSYMBOL TABLE\n";
        cout << "no.\tname\taddress\n";
        int ind = 0;
        ofstream sym("symbol_table.txt");
        for (auto& i : symTab) {
            cout << ind << "\t" << i.first << "\t" << i.second << endl;
            sym<<i.first<<"\t"<<i.second<<endl;
            ind++;
        }
        sym.close();
        ofstream lit("literal_table.txt");
        cout << "\nLITERAL TABLE\n";
        cout << "no.\tname\taddress\n";
        ind = 0;
        for (auto& i : litTab) {
            cout << ind << "\t" << i.first << "\t" << i.second << endl;
            lit<<i.first<<"\t"<<i.second<<endl;
            ind++;
        }
        lit.close();
        cout << "\nPOOL TABLE\n";
        for (auto& i : poolTab)
            cout << i << endl;
    }
};

vector<string> splitWord(const string &line) {
    vector<string> words;
    string word;
    for (int i = 0 ;i<line.size() ;i++) {
        if (line[i] != ' ' && line[i]!=',') {
            word += line[i];
        } 
        else if (!word.empty()) {
            words.push_back(word);
            word.clear();
        }
    }

    if (!word.empty()) {
        words.push_back(word);
    }

    return words;
}

