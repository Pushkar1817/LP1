#include<iostream>
#include <algorithm>
#include <vector>
#include <queue>
using namespace std;

class Processes{
    public:
        string name ;
        int arr_time;
        int burst_time;
        int wait_time;
        int turnAround;
        int comp_time;
        int priority;

        Processes(){
            name = "";
            arr_time = 0;
            burst_time = 0;
            wait_time = 0;
            turnAround = 0;
            comp_time = 0;
            priority = 0;
        }

        void create(){
            cout<<"Enter the Process Name : ";
            cin>>name;
            cout<<"Arrival Time : ";
            cin>>arr_time;
            cout<<"Brust Time : ";
            cin>>burst_time;
        }

        friend class Schedular;
};

class Scheduler{
    private:
        Processes * process;
        int n;
    public:
        Scheduler(){
            cout<<"Enter the number of Processes : ";
            cin>> n;
            process = new Processes[n];

            for(int i = 0 ;i< n ;i++){
                process[i].create();
                cout<<endl;
            }
        }
        void display(Processes temp[],int n){
            cout << "Process\tAT\tBT\tCT\tT_AT\tWT" << endl;

            for(int i = 0 ;i< n ;i++){
                cout << temp[i].name << "\t" << temp[i].arr_time << "\t"
                     << temp[i].burst_time << "\t"<<temp[i].comp_time<<"\t" << temp[i].turnAround
                     << "\t" << temp[i].wait_time << endl;               
            }
        }
        void average(float avg_tat,float avg_wt){
            cout<<"\nAverage Turnaround Time : "<<avg_tat;
            cout<<"\nAverage Waiting Time : "<<avg_wt;
        }

        void FCFS(){
            Processes temp[n];

            for(int i = 0 ; i<  n ;i++)
                temp[i] = process[i];

            sort(temp, temp + n, []( Processes a,  Processes b) {
                return a.arr_time < b.arr_time;
            });

            int ct = 0 ;

            for(int i = 0 ;i< n ;i++){
                ct += temp[i].burst_time;

                temp[i].comp_time = ct ;
                temp[i].turnAround = temp[i].comp_time - temp[i].arr_time;
                temp[i].wait_time = temp[i].turnAround - temp[i].burst_time;
            }

            float avg_tat = 0;
            float avg_wt = 0;

            for(int i = 0 ;i< n; i++){
                avg_tat += temp[i].turnAround;
                avg_wt += temp[i].wait_time;
            }
            avg_tat /=n;
            avg_wt /=n;

            display(temp,n);
            average(avg_tat,avg_wt);
        }

    void SJF_preemptive() {
        Processes temp[n];
        int totalTime = 0;
        for (int i = 0; i < n; i++) {
            temp[i] = process[i];
            totalTime += process[i].burst_time;
        }

        sort(temp, temp + n, [](const Processes &a, const Processes &b) {
            return a.arr_time < b.arr_time;
        });

        vector<string> gantt;
        int aj = 0;
        int timeStamp = 0;
        auto cmp = [](const Processes &a, const Processes &b) {
            return a.burst_time > b.burst_time;
        };
        priority_queue<Processes, vector<Processes>, decltype(cmp)> readyQ(cmp);

        while (timeStamp < totalTime) {
            while (aj < n && temp[aj].arr_time <= timeStamp) {
                readyQ.push(temp[aj]);
                aj++;
            }

            if (!readyQ.empty()) {
                Processes miniBurst = readyQ.top();
                readyQ.pop();
                if (gantt.empty() || gantt.back() != miniBurst.name ) {
                    gantt.push_back(miniBurst.name );
                }
                miniBurst.burst_time--;

                if (miniBurst.burst_time == 0) {
                    for (int i = 0; i < n; i++) {
                        if (temp[i].name == miniBurst.name) {
                            temp[i].comp_time = timeStamp + 1;
                            temp[i].turnAround = temp[i].comp_time - temp[i].arr_time;
                            temp[i].wait_time = temp[i].turnAround - temp[i].burst_time;
                            break;
                        }
                    }
                } else {
                    readyQ.push(miniBurst);
                }
            }
            timeStamp++;
        }

        float avg_tat = 0, avg_wt = 0;
        for (int i = 0; i < n; i++) {
            avg_tat += temp[i].turnAround;
            avg_wt += temp[i].wait_time;
        }

        avg_tat /= n;
        avg_wt /= n;
        display(temp, n);
        average(avg_tat, avg_wt);
        cout<<"\nGantt Chart : ";
        for(int i = 0 ;i< gantt.size() ;i++){
            cout<<gantt[i]<<"  ";
        }
        cout<<endl;
    }

    void roundRobin() {
        Processes temp[n];
        int totalTime = 0;
        for (int i = 0; i < n; i++) {
            temp[i] = process[i];
            totalTime += process[i].burst_time;
        }
        int time_quantum;
        cout << "Enter Time Quantum: ";
        cin >> time_quantum;

        sort(temp, temp + n, [](const Processes &a, const Processes &b) {
            return a.arr_time < b.arr_time;
        });

        vector<string> gantt;
        int aj = 0;
        int timeStamp = 0;
        int finish = 0;
        queue<Processes> readyQ;

        while (finish < n) {
            while (aj < n && temp[aj].arr_time <= timeStamp) {
                readyQ.push(temp[aj]);
                aj++;
            }

            if (!readyQ.empty()) {
                Processes currProc = readyQ.front();
                readyQ.pop();
                gantt.push_back(currProc.name);

                int timeSpent = min(time_quantum, currProc.burst_time);
                currProc.burst_time -= timeSpent;
                timeStamp += time_quantum;

                if (currProc.burst_time <= 0) {
                    for (int i = 0; i < n; i++) {
                        if (temp[i].name == currProc.name) {
                            temp[i].comp_time = timeStamp;
                            temp[i].turnAround = temp[i].comp_time - temp[i].arr_time;
                            temp[i].wait_time = temp[i].turnAround - temp[i].burst_time;
                            finish++;
                            break;
                        }
                    }
                } else {
                    while (aj < n && temp[aj].arr_time <= timeStamp) {
                        readyQ.push(temp[aj]);
                        aj++;
                    }
                    readyQ.push(currProc);
                }
            }
        }

        float avg_tat = 0, avg_wt = 0;
        for (int i = 0; i < n; i++) {
            avg_tat += temp[i].turnAround;
            avg_wt += temp[i].wait_time;
        }

        avg_tat /= n;
        avg_wt /= n;
        display(temp, n);
        average(avg_tat, avg_wt);

        cout << "\nGantt Chart: ";
        for (int i = 0; i < gantt.size(); i++) {
            cout << gantt[i] << "  ";
        }
        cout << endl;
    }

    void priority_non_preemptive(){
        Processes temp[n];

        for (int i = 0; i < n; i++)
        {
            cout<<"Give Priority for "<<process[i].name<<" : ";
            cin>>process[i].priority;
            temp[i] = process[i];
        }

        sort(temp, temp + n, [](const Processes &a, const Processes &b)
             { return a.priority > b.priority; });

        int ct = 0;
        Processes gantt[n];

        for (int i = 0; i < n; i++)
        {
            gantt[i] = temp[i];
            ct += gantt[i].burst_time;

            gantt[i].comp_time = ct;
            gantt[i].turnAround = gantt[i].comp_time - gantt[i].arr_time;
            gantt[i].wait_time = gantt[i].turnAround - gantt[i].burst_time;
        }

        float avg_tat = 0, avg_wt = 0;
        for (int i = 0; i < n; i++)
        {
            avg_tat += gantt[i].turnAround;
            avg_wt += gantt[i].wait_time;
        }
        avg_tat = avg_tat / n;
        avg_wt = avg_wt / n;

        display(gantt, n);
        average(avg_tat, avg_wt);
    }

};



